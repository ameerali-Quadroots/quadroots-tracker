<!DOCTYPE html>
<html>
  <head>
    <title>ClockInClockOut</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap JS (for modals, dropdowns, etc.) -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" defer></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
  <link href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" rel="stylesheet"/>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
<%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>

  </head>

  <body>
       <script>
    <% if flash[:notice] %>
      toastr.success("<%= j flash[:notice] %>");
    <% end %>

    <% if flash[:alert] %>
      toastr.error("<%= j flash[:alert] %>");
    <% end %>

    <% if flash[:error] %>
      toastr.error("<%= j flash[:error] %>");
    <% end %>
    toastr.options = {
  "closeButton": true,
  "progressBar": true,
  "positionClass": "toast-top-right",
  "timeOut": "3000",
  "showDuration": "300",
  "hideDuration": "1000",
  "showMethod": "fadeIn",   // 👈 fade in
  "hideMethod": "fadeOut"   // 👈 fade out
}
  </script>
  <% if user_signed_in? %>
  <script src="https://js.pusher.com/8.4.0/pusher.min.js"></script>
  <script>
    (function() {
      var csrfToken   = document.querySelector('meta[name="csrf-token"]').getAttribute('content');
      var vapidKey    = '<%= ENV['VAPID_PUBLIC_KEY'] %>';

      /* ---------- helpers ---------- */
      function urlBase64ToUint8Array(b64) {
        var padding = '='.repeat((4 - b64.length % 4) % 4);
        var base64  = (b64 + padding).replace(/-/g, '+').replace(/_/g, '/');
        var raw     = atob(base64);
        var arr     = new Uint8Array(raw.length);
        for (var i = 0; i < raw.length; i++) arr[i] = raw.charCodeAt(i);
        return arr;
      }

      function showToast(title, message) {
        toastr.info(message, title, {
          timeOut: 0, extendedTimeOut: 0,
          closeButton: true, progressBar: false,
          positionClass: 'toast-top-right'
        });
      }

      /* ---------- Web Push (works on localhost even without HTTPS) ---------- */
      function saveSub(sub) {
        var s = sub.toJSON();
        fetch('/push_subscriptions', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': csrfToken },
          body: JSON.stringify({ endpoint: s.endpoint, keys: s.keys })
        });
      }

      if ('serviceWorker' in navigator && 'PushManager' in window && vapidKey) {
        navigator.serviceWorker.register('/service-worker.js')
          .then(function(reg) {
            return Notification.requestPermission().then(function(perm) {
              if (perm !== 'granted') return;
              return reg.pushManager.getSubscription().then(function(existing) {
                if (existing) { saveSub(existing); return existing; }
                return reg.pushManager.subscribe({
                  userVisibleOnly: true,
                  applicationServerKey: urlBase64ToUint8Array(vapidKey)
                }).then(function(sub) { saveSub(sub); return sub; });
              });
            });
          })
          .catch(function(e) { console.warn('Web Push setup failed:', e); });
      }

      /* ---------- DB polling — shows missed notifications on tab reopen ---------- */
      function checkUnread() {
        fetch('/notifications/unread', {
          headers: { 'X-CSRF-Token': csrfToken, 'Accept': 'application/json' }
        })
        .then(function(r) { return r.ok ? r.json() : []; })
        .then(function(list) { list.forEach(function(n) { showToast(n.title, n.message); }); })
        .catch(function() {});
      }
      checkUnread();
      setInterval(checkUnread, 30000);
      document.addEventListener('visibilitychange', function() { if (!document.hidden) checkUnread(); });

      /* ---------- Pusher — instant toast while tab is open ---------- */
      <% if ENV['PUSHER_APP_KEY'].present? %>
      var pusher  = new Pusher('<%= ENV['PUSHER_APP_KEY'] %>', {
        cluster: '<%= ENV['PUSHER_APP_CLUSTER'] %>',
        channelAuthorization: { endpoint: '/pusher/auth', headers: { 'X-CSRF-Token': csrfToken } }
      });
      var channel = pusher.subscribe('private-user-<%= current_user.id %>');
      channel.bind('new-edit-request',  function(d) { showToast(d.title, d.message); });
      channel.bind('new-leave-request', function(d) { showToast(d.title, d.message); });
      <% end %>
    })();
  </script>
  <% end %>

  <div class="container-fluid">

    <div class="row">
      <% if user_signed_in? %>
        <%= render 'layouts/navbar' %>
      <% end %>

      <!-- Main Content Area -->
      <main>
        <%= yield %>
      </main>
    </div>
  </div>
 
  </body>
</html>
