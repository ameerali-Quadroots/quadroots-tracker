<!DOCTYPE html>
<html>
  <head>
    <title>ClockInClockOut</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap JS (for modals, dropdowns, etc.) -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" defer></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
  <link href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" rel="stylesheet"/>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
<%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>

  </head>

  <body>
       <script>
    <% if flash[:notice] %>
      toastr.success("<%= j flash[:notice] %>");
    <% end %>

    <% if flash[:alert] %>
      toastr.error("<%= j flash[:alert] %>");
    <% end %>

    <% if flash[:error] %>
      toastr.error("<%= j flash[:error] %>");
    <% end %>
    toastr.options = {
  "closeButton": true,
  "progressBar": true,
  "positionClass": "toast-top-right",
  "timeOut": "3000",
  "showDuration": "300",
  "hideDuration": "1000",
  "showMethod": "fadeIn",   // 👈 fade in
  "hideMethod": "fadeOut"   // 👈 fade out
}
  </script>
  <% if user_signed_in? && ENV['PUSHER_APP_KEY'].present? %>
  <script src="https://js.pusher.com/8.4.0/pusher.min.js"></script>
  <script>
    (function() {
      // Request browser notification permission on page load
      if ('Notification' in window && Notification.permission === 'default') {
        Notification.requestPermission();
      }

      function showBrowserNotification(title, body) {
        if ('Notification' in window && Notification.permission === 'granted') {
          var n = new Notification(title, {
            body: body,
            icon: '/icon.png',
            tag: title
          });
          n.onclick = function() { window.focus(); n.close(); };
          setTimeout(function() { n.close(); }, 10000);
        }
      }

      var pusher = new Pusher('<%= ENV['PUSHER_APP_KEY'] %>', {
        cluster: '<%= ENV['PUSHER_APP_CLUSTER'] %>',
        channelAuthorization: {
          endpoint: '/pusher/auth',
          headers: {
            'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').getAttribute('content')
          }
        }
      });

      var channel = pusher.subscribe('private-user-<%= current_user.id %>');

      channel.bind('new-edit-request', function(data) {
        toastr.info(data.message, 'New Edit Request', {
          timeOut: 10000,
          closeButton: true,
          progressBar: true,
          positionClass: 'toast-top-right'
        });
        showBrowserNotification('New Edit Request', data.message);
      });

      channel.bind('new-leave-request', function(data) {
        toastr.info(data.message, 'New Leave Request', {
          timeOut: 10000,
          closeButton: true,
          progressBar: true,
          positionClass: 'toast-top-right'
        });
        showBrowserNotification('New Leave Request', data.message);
      });
    })();
  </script>
  <% end %>

  <div class="container-fluid">

    <div class="row">
      <% if user_signed_in? %>
        <%= render 'layouts/navbar' %>
      <% end %>

      <!-- Main Content Area -->
      <main>
        <%= yield %>
      </main>
    </div>
  </div>
 
  </body>
</html>
