<div class="page-shell">
  <div class="table-card">

    <!-- Header -->
    <div class="table-card__head">
      <h1 class="table-card__title">
        <span class="icon"><i class="fas fa-calendar-day"></i></span>
        <span>
          My Leaves
          <span class="table-card__subtitle">Your submitted leave requests</span>
        </span>
      </h1>
      <div class="table-card__stats">
        <span class="stat-pill"><b><%= @leaves.count %></b> Total</span>
        <span class="stat-pill"><b><%= @leaves.select { |l| l.status == "pending" }.size %></b> Pending</span>
        <span class="stat-pill"><b><%= @leaves.select { |l| l.status == "approved" }.size %></b> Approved</span>
      </div>
    </div>

    <!-- Filters -->
    <%= form_with url: my_leaves_leaves_path, method: :get, local: true, class: "table-filter" do |f| %>
      <div class="field">
        <%= f.label :status, "Status" %>
        <%= f.select :status, [["All", ""], ["Pending", "pending"], ["Approved", "approved"], ["Rejected", "rejected"]],
              { selected: params[:status] }, class: "form-select" %>
      </div>
      <div class="field">
        <%= f.label :from_date, "From" %>
        <%= f.date_field :from_date, value: params[:from_date], class: "form-control" %>
      </div>
      <div class="field">
        <%= f.label :to_date, "To" %>
        <%= f.date_field :to_date, value: params[:to_date], class: "form-control" %>
      </div>
      <%= f.submit "Filter", class: "btn-filter" %>
      <%= link_to "Reset", my_leaves_leaves_path, class: "btn-reset" %>
    <% end %>

    <!-- Table -->
    <% if @leaves.any? %>
      <div class="premium-table-wrap">
        <table class="premium-table">
          <thead>
            <tr>
              <th>Leave Type</th>
              <th>Start Date</th>
              <th>End Date</th>
              <th>Reason</th>
              <th>Approved By Manager</th>
              <th>Status</th>
              <th>Requested At</th>
              <th>Resolved At</th>
            </tr>
          </thead>
          <tbody>
            <% @leaves.each do |leave| %>
              <tr>
                <td><span class="type-tag text-capitalize"><%= leave.leave_type %></span></td>
                <td><div class="date-cell"><div class="d"><%= leave.start_date.strftime("%b %d, %Y") %></div></div></td>
                <td><div class="date-cell"><div class="d"><%= leave.end_date.strftime("%b %d, %Y") %></div></div></td>
                <td><div class="reason-cell"><%= leave.reason %></div></td>
                <td>
                  <span class="pill <%= leave.approved_by_manager? ? 'pill--yes' : 'pill--no' %>">
                    <%= leave.approved_by_manager? ? 'Yes' : 'No' %>
                  </span>
                </td>
                <td><span class="pill pill--<%= leave.status %>"><%= leave.status.capitalize %></span></td>
                <td>
                  <div class="date-cell">
                    <div class="d"><%= leave.created_at.strftime("%b %d, %Y") %></div>
                    <div class="t"><%= leave.created_at.strftime("%I:%M %p") %></div>
                  </div>
                </td>
                <td>
                  <div class="date-cell">
                    <div class="d"><%= leave.updated_at.strftime("%b %d, %Y") %></div>
                    <div class="t"><%= leave.updated_at.strftime("%I:%M %p") %></div>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="table-empty">
        <i class="bi bi-calendar-x"></i>
        <h5>No leaves yet</h5>
        <p class="mb-0">Your submitted leave requests will appear here.</p>
      </div>
    <% end %>

  </div>
</div>
