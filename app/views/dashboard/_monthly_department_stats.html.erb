<% if @monthly_dept_stats.present? && @monthly_dept_stats.values.any?(&:any?) %>

<%
  dept_colors = {
    "WEB"     => { header_bg: "#1d4ed8", light_bg: "#eff6ff", badge_bg: "#dbeafe", badge_text: "#1e40af" },
    "SEO"     => { header_bg: "#15803d", light_bg: "#f0fdf4", badge_bg: "#dcfce7", badge_text: "#166534" },
    "CONTENT" => { header_bg: "#6d28d9", light_bg: "#faf5ff", badge_bg: "#ede9fe", badge_text: "#5b21b6" },
    "ADS"     => { header_bg: "#c2410c", light_bg: "#fff7ed", badge_bg: "#ffedd5", badge_text: "#9a3412" },
  }
  default_color = { header_bg: "#334155", light_bg: "#f8fafc", badge_bg: "#e2e8f0", badge_text: "#334155" }
%>

<div class="dashboard-card border-0 shadow-sm" style="border-radius: 14px; background: #ffffff; overflow: hidden;">
  <div class="d-flex align-items-center justify-content-between px-4 py-3" style="border-bottom: 1px solid #f1f5f9; background: linear-gradient(135deg, #ffffff 0%, #fffbeb 100%);">
    <div class="d-flex align-items-center">
      <div class="d-flex justify-content-center align-items-center me-3" style="width: 36px; height: 36px; background: linear-gradient(135deg, #fef3c7, #fde68a); border-radius: 8px; color: #d97706; font-size: 1.0rem;">
        <i class="bi bi-bar-chart-line-fill"></i>
      </div>
      <div>
        <h6 class="mb-0 fw-bold" style="color: #1e293b; font-size: 1.0rem;">Monthly Department Report</h6>
        <div style="font-size: 0.73rem; color: #94a3b8; margin-top: 1px;">Clock-ins · Lates · Half Days — last 12 months</div>
      </div>
    </div>
  </div>

  <div class="p-4" style="background: #fcfcfd;">
    <div class="row g-4">
      <% @target_departments.each do |dept| %>
        <% dept_stats = @monthly_dept_stats[dept] %>
        <% next if dept_stats.blank? %>
        <% colors = dept_colors[dept] || default_color %>

        <div class="col-xl-6">
          <div class="card border-0" style="border-radius: 12px; overflow: hidden; box-shadow: 0 2px 12px rgba(0,0,0,0.06); border: 1px solid #f1f5f9 !important;">
            <div class="px-4 py-3 d-flex align-items-center justify-content-between" style="background: linear-gradient(135deg, <%= colors[:header_bg] %> 0%, <%= colors[:header_bg] %>cc 100%);">
              <div class="d-flex align-items-center">
                <i class="bi bi-diagram-3 me-2" style="color: rgba(255,255,255,0.75); font-size: 0.85rem;"></i>
                <span class="fw-bold text-white" style="font-size: 0.88rem; letter-spacing: 0.5px;"><%= dept %> DEPARTMENT</span>
              </div>
              <span style="font-size: 0.72rem; color: rgba(255,255,255,0.65);"><%= dept_stats.length %> month<%= dept_stats.length != 1 ? 's' : '' %></span>
            </div>

            <div class="table-responsive" style="max-height: 340px; overflow-y: auto;">
              <table class="table table-sm align-middle mb-0">
                <thead style="background: <%= colors[:light_bg] %>; position: sticky; top: 0; z-index: 1;">
                  <tr>
                    <th class="px-3 py-2 text-start" style="font-size: 0.68rem; font-weight: 700; color: #475569; letter-spacing: 0.5px; border-bottom: 1px solid <%= colors[:badge_bg] %>; white-space: nowrap;">MONTH</th>
                    <th class="px-3 py-2 text-center" style="font-size: 0.68rem; font-weight: 700; color: #475569; letter-spacing: 0.5px; border-bottom: 1px solid <%= colors[:badge_bg] %>; white-space: nowrap;">CLOCK-INS</th>
                    <th class="px-3 py-2 text-center" style="font-size: 0.68rem; font-weight: 700; color: #475569; letter-spacing: 0.5px; border-bottom: 1px solid <%= colors[:badge_bg] %>; white-space: nowrap;">LATES</th>
                    <th class="px-3 py-2 text-center" style="font-size: 0.68rem; font-weight: 700; color: #475569; letter-spacing: 0.5px; border-bottom: 1px solid <%= colors[:badge_bg] %>; white-space: nowrap;">HALF DAYS</th>
                  </tr>
                </thead>
                <tbody style="background: #ffffff;">
                  <% dept_stats.each_with_index do |stat, idx| %>
                    <% is_current = stat[:month].year == Date.current.year && stat[:month].month == Date.current.month %>
                    <tr style="background: <%= is_current ? colors[:light_bg] : 'white' %>;">
                      <td class="px-3 py-2" style="border-bottom: 1px solid #f8f9fa;">
                        <span style="font-weight: <%= is_current ? '700' : '600' %>; color: #1e293b; font-size: 0.82rem;">
                          <%= stat[:month].strftime("%b %Y") %>
                        </span>
                        <% if is_current %>
                          <span class="badge ms-1" style="background: <%= colors[:badge_bg] %>; color: <%= colors[:badge_text] %>; font-size: 0.65rem; padding: 2px 6px; border-radius: 20px;">Now</span>
                        <% end %>
                      </td>
                      <td class="px-3 py-2 text-center" style="border-bottom: 1px solid #f8f9fa;">
                        <span style="font-weight: 700; color: <%= colors[:badge_text] %>; font-size: 0.87rem;"><%= stat[:clock_ins] %></span>
                      </td>
                      <td class="px-3 py-2 text-center" style="border-bottom: 1px solid #f8f9fa;">
                        <% if stat[:lates] > 0 %>
                          <span class="badge" style="background: #fee2e2; color: #dc2626; font-size: 0.73rem; padding: 3px 10px; border-radius: 20px; font-weight: 700;"><%= stat[:lates] %></span>
                        <% else %>
                          <span style="color: #cbd5e1; font-size: 0.82rem; font-weight: 600;">—</span>
                        <% end %>
                      </td>
                      <td class="px-3 py-2 text-center" style="border-bottom: 1px solid #f8f9fa;">
                        <% if stat[:half_days] > 0 %>
                          <span class="badge" style="background: #fef3c7; color: #d97706; font-size: 0.73rem; padding: 3px 10px; border-radius: 20px; font-weight: 700;"><%= stat[:half_days] %></span>
                        <% else %>
                          <span style="color: #cbd5e1; font-size: 0.82rem; font-weight: 600;">—</span>
                        <% end %>
                      </td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>
<% end %>
