<%# --- Calculate shift range --- %>
<%
now = Time.zone.now
if now.hour < 4
  shift_start = (now - 1.day).change(hour: 18, min: 30)
  shift_end = now.change(hour: 4)
else
  shift_start = now.change(hour: 18, min: 30)
  shift_end = (now + 1.day).change(hour: 3)
end
shift_range = shift_start..shift_end
%>

<% 
  department = current_user.department
  executives = User.includes(time_clocks: :breaks)
                   .where(department: department)
                   .where.not(id: current_user.id)
%>

<!-- Custom Header mirroring screenshot -->
<div class="d-flex align-items-center px-4 py-3" style="border-bottom: 1px solid #f1f5f9; background-color: #ffffff;">
  <div class="d-flex justify-content-center align-items-center me-3" style="width: 36px; height: 36px; background-color: #f3f0fc; border-radius: 8px; color: #6b52c0; font-size: 1.1rem;">
    <i class="bi bi-people-fill"></i>
  </div>
  <h6 class="mb-0 fw-bold" style="color: #0d6efd; font-size: 1.05rem;">
    Department Executives Status (<%= current_user.department %>)
  </h6>
</div>

<!-- Table mirroring screenshot -->
<div class="table-responsive p-0 m-0">
  <table class="table align-middle mb-0" style="border-collapse: separate; border-spacing: 0;">
    <thead style="background-color: #f8f9fa;">
      <tr>
        <th class="px-5 py-3 text-start" style="font-size: 0.75rem; font-weight: 700; color: #1e293b; letter-spacing: 0.5px; border-bottom: 1px solid #f1f5f9; border-top: 1px solid #f1f5f9;">EXECUTIVE</th>
        <th class="px-4 py-3 text-center" style="font-size: 0.75rem; font-weight: 700; color: #1e293b; letter-spacing: 0.5px; border-bottom: 1px solid #f1f5f9; border-top: 1px solid #f1f5f9;">STATUS</th>
        <th class="px-4 py-3 text-center" style="font-size: 0.75rem; font-weight: 700; color: #1e293b; letter-spacing: 0.5px; border-bottom: 1px solid #f1f5f9; border-top: 1px solid #f1f5f9;">BREAK DETAILS</th>
      </tr>
    </thead>
    <tbody style="background: #ffffff;">
      <% if executives.empty? %>
        <tr>
          <td colspan="3" class="text-center text-muted py-5" style="border-bottom: 1px solid #f1f5f9;">
            <div class="empty-state">
              <i class="bi bi-people display-4 d-block mb-3" style="color: #cbd5e1;"></i>
              <h5 class="fw-bold" style="color: #334155;">No executives found</h5>
              <p class="mb-0">No other executives are in your department.</p>
            </div>
          </td>
        </tr>
      <% else %>
        <% executives.each do |executive| %>
          <% 
            tc = executive.time_clocks.where(clock_in: shift_range).order(clock_in: :desc).first 
            status = "Off"
            break_details = "-"
            status_html = ""

            if tc.present?
              if tc.on_break?
                status = "On Break"
                last_break = tc.breaks.where(break_out: nil).last
                break_details = "#{last_break&.break_type} (Since #{last_break&.break_in&.strftime('%I:%M %p')})"
                status_html = %Q(<span class="badge rounded-pill" style="background-color: #f59e0b; color: #fff; padding: 6px 18px; font-weight: 500; font-size: 0.8rem;">On Break</span>)
              elsif tc.clock_out.nil?
                status = "Active"
                status_html = %Q(<span class="badge rounded-pill" style="background-color: #00b894; color: #fff; padding: 6px 18px; font-weight: 500; font-size: 0.8rem;">Active</span>)
              else
                status = "Off"
                status_html = %Q(<span class="badge rounded-pill" style="background-color: #f1f5f9; color: #475569; border: 1px solid #e2e8f0; padding: 6px 20px; font-weight: 500; font-size: 0.8rem;">Off</span>)
              end
            else
               status_html = %Q(<span class="badge rounded-pill" style="background-color: #f1f5f9; color: #475569; border: 1px solid #e2e8f0; padding: 6px 20px; font-weight: 500; font-size: 0.8rem;">Off</span>)
            end
          %>
          <tr>
            <td class="px-5 py-3 text-start" style="border-bottom: 1px solid #f1f5f9;">
              <div class="d-flex align-items-center">
                <div class="rounded-circle d-flex justify-content-center align-items-center me-3" style="width: 42px; height: 42px; background-color: #eef2ff; color: #0d6efd; font-size: 1.1rem; font-weight: 600;">
                  <%= executive.name.first.upcase %>
                </div>
                <div class="text-start">
                  <div style="font-weight: 700; color: #1e293b; font-size: 0.95rem; line-height: 1.2; margin-bottom: 2px;"><%= executive.name %></div>
                  <div style="color: #64748b; font-size: 0.8rem;"><%= executive.role %></div>
                </div>
              </div>
            </td>
            <td class="px-4 py-3 text-center" style="border-bottom: 1px solid #f1f5f9;">
              <%= raw status_html %>
            </td>
            <td class="px-4 py-3 text-center text-muted" style="border-bottom: 1px solid #f1f5f9; font-size: 0.9rem;">
              <%= break_details %>
            </td>
          </tr>
        <% end %>
      <% end %>
    </tbody>
  </table>
</div>
