<%# --- Calculate shift range --- %>
<%
now = Time.zone.now
if now.hour < 4
  shift_start = (now - 1.day).change(hour: 18, min: 30)
  shift_end = now.change(hour: 4)
else
  shift_start = now.change(hour: 18, min: 30)
  shift_end = (now + 1.day).change(hour: 3)
end
shift_range = shift_start..shift_end
%>

<%
  target_departments = current_user.department == "HOD'S" ? ["WEB", "SEO", "CONTENT", "ADS"] : [current_user.department]

  executives = User.includes(time_clocks: :breaks)
                   .where(department: target_departments, employeed: true)
                   .where.not(id: current_user.id)

  dept_colors = {
    "WEB"     => { header_bg: "#1d4ed8", light_bg: "#eff6ff", badge_bg: "#dbeafe", badge_text: "#1e40af" },
    "SEO"     => { header_bg: "#15803d", light_bg: "#f0fdf4", badge_bg: "#dcfce7", badge_text: "#166534" },
    "CONTENT" => { header_bg: "#6d28d9", light_bg: "#faf5ff", badge_bg: "#ede9fe", badge_text: "#5b21b6" },
    "ADS"     => { header_bg: "#c2410c", light_bg: "#fff7ed", badge_bg: "#ffedd5", badge_text: "#9a3412" },
  }
  default_color = { header_bg: "#334155", light_bg: "#f8fafc", badge_bg: "#e2e8f0", badge_text: "#334155" }

  exec_data_all = executives.map { |e| [e, executive_status_data(e, shift_range)] }

  working_count  = exec_data_all.count { |_, d| d[:status] == 'Working' }
  meeting_count  = exec_data_all.count { |_, d| d[:status] == 'In Meeting' }
  on_break_count = exec_data_all.count { |_, d| !['Working', 'Off', 'In Meeting', 'Downtime'].include?(d[:status]) }
  downtime_count = exec_data_all.count { |_, d| d[:status] == 'Downtime' }
  off_count      = exec_data_all.count { |_, d| d[:status] == 'Off' }
%>

<!-- Section Header -->
<div class="d-flex align-items-center justify-content-between px-4 py-3" style="border-bottom: 1px solid #f1f5f9; background: linear-gradient(135deg, #ffffff 0%, #f8faff 100%);">
  <div class="d-flex align-items-center">
    <div class="d-flex justify-content-center align-items-center me-3" style="width: 36px; height: 36px; background-color: #f3f0fc; border-radius: 8px; color: #6b52c0; font-size: 1.1rem;">
      <i class="bi bi-people-fill"></i>
    </div>
    <h6 class="mb-0 fw-bold" style="color: #0d6efd; font-size: 1.05rem;">
      Department Executives Status (<%= current_user.department == "HOD'S" ? "HOD'S" : current_user.department %>)
    </h6>
  </div>
  <div class="d-flex align-items-center gap-3">
    <span class="text-muted" style="font-size: 0.78rem;"><%= Time.zone.now.strftime("%I:%M %p") %></span>
    <% if action_name != 'team_status' %>
      <a href="/dashboard/team_status" class="btn btn-sm btn-outline-primary" style="font-weight: 500; border-radius: 6px;">
        <i class="bi bi-arrows-fullscreen me-1"></i> Full View
      </a>
    <% end %>
  </div>
</div>

<!-- Summary Stats Bar -->
<div class="px-4 py-2 d-flex align-items-center gap-4 flex-wrap" style="background: #f8faff; border-bottom: 1px solid #f1f5f9;">
  <div class="d-flex align-items-center gap-2">
    <div style="width: 9px; height: 9px; border-radius: 50%; background-color: #00b894; box-shadow: 0 0 0 2px #d1fae5;"></div>
    <span style="font-size: 0.80rem; color: #1e293b; font-weight: 600;"><%= working_count %> Working</span>
  </div>
  <div class="d-flex align-items-center gap-2">
    <div style="width: 9px; height: 9px; border-radius: 50%; background-color: #17a2b8; box-shadow: 0 0 0 2px #cffafe;"></div>
    <span style="font-size: 0.80rem; color: #1e293b; font-weight: 600;"><%= meeting_count %> In Meeting</span>
  </div>
  <div class="d-flex align-items-center gap-2">
    <div style="width: 9px; height: 9px; border-radius: 50%; background-color: #f59e0b; box-shadow: 0 0 0 2px #fef3c7;"></div>
    <span style="font-size: 0.80rem; color: #1e293b; font-weight: 600;"><%= on_break_count %> On Break</span>
  </div>
  <% if downtime_count > 0 %>
    <div class="d-flex align-items-center gap-2">
      <div style="width: 9px; height: 9px; border-radius: 50%; background-color: #dc3545; box-shadow: 0 0 0 2px #fee2e2;"></div>
      <span style="font-size: 0.80rem; color: #1e293b; font-weight: 600;"><%= downtime_count %> Downtime</span>
    </div>
  <% end %>
  <div class="d-flex align-items-center gap-2">
    <div style="width: 9px; height: 9px; border-radius: 50%; background-color: #94a3b8; box-shadow: 0 0 0 2px #e2e8f0;"></div>
    <span style="font-size: 0.80rem; color: #1e293b; font-weight: 600;"><%= off_count %> Off</span>
  </div>
  <div class="ms-auto">
    <span style="font-size: 0.75rem; color: #94a3b8;"><%= executives.count %> total</span>
  </div>
</div>

<!-- Department Grid Area -->
<div class="p-4" style="background-color: #fcfcfd;">
  <div class="row g-4">
    <% if executives.empty? %>
      <div class="col-12 text-center text-muted py-5">
        <i class="bi bi-people display-4 d-block mb-3" style="color: #cbd5e1;"></i>
        <h5 class="fw-bold" style="color: #334155;">No executives found</h5>
        <p class="mb-0">No other executives are in your department.</p>
      </div>
    <% else %>
      <% target_departments.each do |dept| %>
        <% dept_exec_data = exec_data_all.select { |e, _| e.department == dept } %>
        <% next if dept_exec_data.empty? && target_departments.length > 1 %>
        <% colors = dept_colors[dept] || default_color %>

        <% dept_working  = dept_exec_data.count { |_, d| d[:status] == 'Working' } %>
        <% dept_meeting  = dept_exec_data.count { |_, d| d[:status] == 'In Meeting' } %>
        <% dept_on_break = dept_exec_data.count { |_, d| !['Working', 'Off', 'In Meeting', 'Downtime'].include?(d[:status]) } %>

        <div class="<%= target_departments.length > 1 ? 'col-xl-6' : 'col-12' %>">
          <div class="card h-100 border-0" style="border-radius: 14px; overflow: hidden; box-shadow: 0 4px 20px rgba(0,0,0,0.07); border: 1px solid #f1f5f9 !important;">

            <% if target_departments.length > 1 %>
              <div class="card-header px-4 py-3 d-flex align-items-center justify-content-between" style="background: linear-gradient(135deg, <%= colors[:header_bg] %> 0%, <%= colors[:header_bg] %>cc 100%); border-bottom: none;">
                <div class="d-flex align-items-center">
                  <div class="d-flex justify-content-center align-items-center rounded-circle me-2" style="width: 30px; height: 30px; background-color: rgba(255,255,255,0.18); color: #fff;">
                    <i class="bi bi-diagram-3" style="font-size: 0.85rem;"></i>
                  </div>
                  <span class="fw-bold text-white" style="font-size: 0.92rem; letter-spacing: 0.5px;"><%= dept %> DEPARTMENT</span>
                </div>
                <div class="d-flex gap-2">
                  <% if dept_working > 0 %>
                    <span class="badge" style="background: rgba(255,255,255,0.18); color: #fff; font-size: 0.70rem; padding: 3px 9px; border-radius: 20px;"><%= dept_working %> working</span>
                  <% end %>
                  <% if dept_meeting > 0 %>
                    <span class="badge" style="background: rgba(255,255,255,0.18); color: #fff; font-size: 0.70rem; padding: 3px 9px; border-radius: 20px;"><%= dept_meeting %> meeting</span>
                  <% end %>
                  <% if dept_on_break > 0 %>
                    <span class="badge" style="background: rgba(255,255,255,0.18); color: #fff; font-size: 0.70rem; padding: 3px 9px; border-radius: 20px;"><%= dept_on_break %> break</span>
                  <% end %>
                </div>
              </div>
            <% end %>

            <div class="table-responsive m-0 p-0" style="max-height: 420px; overflow-y: auto;">
              <table class="table align-middle mb-0" style="border-collapse: collapse;">
                <thead style="background: linear-gradient(to right, <%= colors[:light_bg] %>, #ffffff); position: sticky; top: 0; z-index: 1;">
                  <tr>
                    <th class="px-4 py-3 text-start" style="font-size: 0.68rem; font-weight: 700; color: #475569; letter-spacing: 0.5px; border-bottom: 2px solid <%= colors[:badge_bg] %>;">EXECUTIVE</th>
                    <th class="px-3 py-3 text-center" style="font-size: 0.68rem; font-weight: 700; color: #475569; letter-spacing: 0.5px; border-bottom: 2px solid <%= colors[:badge_bg] %>;">STATUS</th>
                    <th class="px-3 py-3 text-center" style="font-size: 0.68rem; font-weight: 700; color: #475569; letter-spacing: 0.5px; border-bottom: 2px solid <%= colors[:badge_bg] %>;">LIVE</th>
                    <th class="px-3 py-3 text-center" style="font-size: 0.68rem; font-weight: 700; color: #475569; letter-spacing: 0.5px; border-bottom: 2px solid <%= colors[:badge_bg] %>;">MEETINGS</th>
                    <th class="px-3 py-3 text-center" style="font-size: 0.68rem; font-weight: 700; color: #475569; letter-spacing: 0.5px; border-bottom: 2px solid <%= colors[:badge_bg] %>;">MTG DUR.</th>
                    <th class="px-3 py-3 text-center" style="font-size: 0.68rem; font-weight: 700; color: #475569; letter-spacing: 0.5px; border-bottom: 2px solid <%= colors[:badge_bg] %>;">BREAKS</th>
                    <th class="px-3 py-3 text-center" style="font-size: 0.68rem; font-weight: 700; color: #475569; letter-spacing: 0.5px; border-bottom: 2px solid <%= colors[:badge_bg] %>;">BRK DUR.</th>
                    <th class="px-3 py-3 text-center" style="font-size: 0.68rem; font-weight: 700; color: #475569; letter-spacing: 0.5px; border-bottom: 2px solid <%= colors[:badge_bg] %>;">SHEET</th>
                  </tr>
                </thead>
                <tbody style="background: #ffffff;">
                  <% if dept_exec_data.empty? %>
                    <tr>
                      <td colspan="8" class="text-center text-muted py-4"><small>No active executives</small></td>
                    </tr>
                  <% else %>
                    <% dept_exec_data.each do |executive, data| %>
                      <% status_html       = data[:status_html] %>
                      <% live_label        = data[:live_label] %>
                      <% meetings_count    = data[:meetings_count] %>
                      <% meeting_dur_label = data[:meeting_duration_label] %>
                      <% breaks_count      = data[:breaks_count] %>
                      <% break_dur_label   = data[:break_duration_label] %>
                      <% break_since       = data[:break_since] %>
                      <% row_bg = case data[:status]
                                  when 'Working'    then '#f0fff8'
                                  when 'In Meeting' then '#f0f9ff'
                                  when 'Downtime'   then '#fff5f5'
                                  else 'white'
                                  end %>

                      <tr style="background: <%= row_bg %>;">
                        <td class="px-4 py-3 text-start" style="border-bottom: 1px solid #f8f9fa;">
                          <div class="d-flex align-items-center">
                            <div class="rounded-circle d-flex justify-content-center align-items-center me-3" style="width: 36px; height: 36px; min-width: 36px; background: linear-gradient(135deg, <%= colors[:badge_bg] %>, <%= colors[:light_bg] %>); color: <%= colors[:header_bg] %>; font-size: 0.92rem; font-weight: 700;">
                              <%= executive.name.first.upcase %>
                            </div>
                            <div class="text-start">
                              <div style="font-weight: 700; color: #1e293b; font-size: 0.87rem; line-height: 1.2; margin-bottom: 2px;"><%= executive.name %></div>
                              <div style="color: #94a3b8; font-size: 0.70rem;"><%= executive.role %></div>
                            </div>
                          </div>
                        </td>
                        <td class="px-3 py-3 text-center" style="border-bottom: 1px solid #f8f9fa;">
                          <%= raw status_html %>
                        </td>
                        <td class="px-3 py-3 text-center" style="border-bottom: 1px solid #f8f9fa; font-size: 0.83rem; color: #1e293b; font-weight: 600;">
                          <%= live_label %>
                        </td>
                        <td class="px-3 py-3 text-center" style="border-bottom: 1px solid #f8f9fa; font-size: 0.83rem; color: #17a2b8; font-weight: 600;">
                          <%= meetings_count %>
                        </td>
                        <td class="px-3 py-3 text-center text-muted" style="border-bottom: 1px solid #f8f9fa; font-size: 0.80rem;">
                          <%= meeting_dur_label %>
                          <% if break_since.present? && data[:current_break_type] == 'Meeting' %>
                            <div style="font-size: 0.70rem; color: #94a3b8;">(Since <%= break_since %>)</div>
                          <% end %>
                        </td>
                        <td class="px-3 py-3 text-center" style="border-bottom: 1px solid #f8f9fa; font-size: 0.83rem; color: #f59e0b; font-weight: 600;">
                          <%= breaks_count %>
                        </td>
                        <td class="px-3 py-3 text-center text-muted" style="border-bottom: 1px solid #f8f9fa; font-size: 0.80rem;">
                          <%= break_dur_label %>
                          <% if break_since.present? && data[:current_break_type] != 'Meeting' %>
                            <div style="font-size: 0.70rem; color: #94a3b8;">(Since <%= break_since %>)</div>
                          <% end %>
                        </td>
                        <td class="px-3 py-3 text-center" style="border-bottom: 1px solid #f8f9fa;">
                          <a href="/dashboard/executive_timesheets/<%= executive.id %>" title="View Timesheets" style="display:inline-flex; align-items:center; justify-content:center; width:30px; height:30px; border-radius:8px; background:<%= colors[:badge_bg] %>; color:<%= colors[:header_bg] %>; text-decoration:none; font-size:0.85rem;">
                            <i class="bi bi-calendar3"></i>
                          </a>
                        </td>
                      </tr>
                    <% end %>
                  <% end %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      <% end %>
    <% end %>
  </div>
</div>
