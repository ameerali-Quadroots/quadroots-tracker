<!-- ✅ Page Title -->
<h3 class="text-center my-4">
  Employee Timesheet Calendar for <%= @employee.name %>
</h3>

<!-- ✅ Month Navigation -->
<div class="calendar-nav text-center mb-3 my-4">
  <% current_month = params[:month] ? Date.parse(params[:month]) : Date.current %>
  <% prev_month = current_month.prev_month %>
  <% next_month = current_month.next_month %>

  <%= link_to "← #{prev_month.strftime('%B')}",
              dashboard_executive_timesheets_path(@employee, month: prev_month),
              class: "btn btn-sm btn-outline-secondary" %>

  <strong class="mx-3"><%= current_month.strftime("%B %Y") %></strong>

  <%= link_to "#{next_month.strftime('%B')} →",
              dashboard_executive_timesheets_path(@employee, month: next_month),
              class: "btn btn-sm btn-outline-secondary" %>
</div>

<!-- ✅ Calendar Grid -->
<div class="attendance-calendar">
  <% start_date = current_month.beginning_of_month.beginning_of_week(:sunday) %>
  <% end_date = current_month.end_of_month.end_of_week(:sunday) %>

  <% (start_date..end_date).each_slice(7) do |week| %>
    <div class="week">
      <% week.each do |day| %>
        <% record = @time_clocks.find { |t| t.clock_in.to_date == day } %>

        <% status_class =
          if record&.status == "late"
            "late"
          elsif record
            "on-time"
          else
            "no-data"
          end
        %>

        <div class="day <%= status_class %> <%= 'dimmed' if day.month != current_month.month %>" 
             title="<%= day.strftime('%B %d, %Y') %>">
          <div class="day-number"><%= day.day %></div>
          <% if record %>
            <div class="clock-time"><%= record.clock_in.strftime("%I:%M %p") %></div>
          <% end %>
        </div>
      <% end %>
    </div>
  <% end %>
</div>

<!-- ✅ Legend -->
<div class="legend">
  <div><span class="box on-time"></span> On Time</div>
  <div><span class="box late"></span> Late</div>
  <div><span class="box no-data"></span> No Record</div>
</div>

<div class="text-center mt-5">
  <a href="/" class="btn btn-primary" style="padding: 10px 20px; font-weight: 500; border-radius: 8px;">Back to Dashboard</a>
</div>

<style nonce="<%= content_security_policy_nonce %>">
  h3.text-center {
    font-weight: 600;
    color: #333;
    font-size: 2rem;
  }

  .calendar-nav {
    margin-bottom: 20px;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 5rem;
  }

  .btn {
    padding: 8px 16px;
    border-radius: 8px;
    border: 1px solid #ccc;
    text-decoration: none;
    color: #333;
    background: #fff;
    transition: all 0.2s ease;
  }

  .btn:hover {
    background: #0d6efd;
    color: #fff;
    border-color: #0d6efd;
  }

  .btn-primary {
    background: #0d6efd;
    color: white;
  }
  .btn-primary:hover {
    background: #0b5ed7;
  }

  .attendance-calendar {
    display: flex;
    flex-direction: column;
    gap: 12px;
    justify-content: center;
    align-items: center;
    margin-bottom: 30px;
  }

  .week {
    display: flex;
    gap: 12px;
  }

  .day {
    width: 75px; 
    height: 75px; 
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    font-weight: 600;
    font-size: 18px;
    border-radius: 10px;
    border: 1px solid #ccc;
    background-color: #fff;
    color: #333;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }

  .day:hover {
    transform: scale(1.10);
    box-shadow: 0 0 8px rgba(0, 0, 0, 0.2);
  }

  .day .clock-time {
    font-size: 11px;
    font-weight: normal;
    margin-top: 4px;
  }

  .day.on-time {
    background-color: #27ae60;
    color: #fff;
    border: none;
  }

  .day.late {
    background-color: #e74c3c;
    color: #fff;
    border: none;
  }

  .day.no-data {
    background-color: #f0f0f0;
    color: #999;
  }

  .day.dimmed {
    opacity: 0.4;
  }

  .legend {
    display: flex;
    justify-content: center;
    gap: 30px;
    font-weight: 500;
    font-size: 16px;
  }

  .legend .box {
    display: inline-block;
    width: 20px;
    height: 20px;
    border-radius: 5px;
    margin-right: 10px;
    vertical-align: middle;
  }

  @media (max-width: 600px) {
    .day {
      width: 55px;
      height: 55px;
      font-size: 14px;
    }
    .day .clock-time {
      font-size: 9px;
    }
    .legend {
      flex-direction: column;
      align-items: center;
      gap: 12px;
    }
  }
</style>
