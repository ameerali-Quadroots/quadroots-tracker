<div class="page-shell">
  <div class="table-card">

    <!-- Header -->
    <div class="table-card__head">
      <h1 class="table-card__title">
        <span class="icon"><i class="fas fa-clock-rotate-left"></i></span>
        <span>
          My Edit Requests
          <span class="table-card__subtitle">Your clock-in / break edit requests</span>
        </span>
      </h1>
      <div class="table-card__stats">
        <span class="stat-pill"><b><%= @edit_requests.count %></b> Total</span>
        <span class="stat-pill"><b><%= @edit_requests.select { |r| r.status == "pending" }.size %></b> Pending</span>
        <span class="stat-pill"><b><%= @edit_requests.select { |r| r.status == "approved" }.size %></b> Approved</span>
      </div>
    </div>

    <!-- Filters -->
    <%= form_with url: my_requests_edit_requests_path, method: :get, local: true, class: "table-filter" do |f| %>
      <div class="field">
        <%= f.label :status, "Status" %>
        <%= f.select :status, [["All", ""], ["Pending", "pending"], ["Approved", "approved"], ["Rejected", "rejected"]],
              { selected: params[:status] }, class: "form-select" %>
      </div>
      <div class="field">
        <%= f.label :request_type, "Request Type" %>
        <%= f.select :request_type, [["All", ""], ['Forgot to end break', 'Forgot to end break'],
                ['Forgot to add break', 'Forgot to add break'],
                ['Clock tower not working', 'Clock tower not working']],
              { selected: params[:request_type] }, class: "form-select" %>
      </div>
      <div class="field">
        <%= f.label :from_date, "From" %>
        <%= f.date_field :from_date, value: params[:from_date], class: "form-control" %>
      </div>
      <div class="field">
        <%= f.label :to_date, "To" %>
        <%= f.date_field :to_date, value: params[:to_date], class: "form-control" %>
      </div>
      <%= f.submit "Filter", class: "btn-filter" %>
      <%= link_to "Reset", my_requests_edit_requests_path, class: "btn-reset" %>
    <% end %>

    <!-- Table -->
    <% if @edit_requests.any? %>
      <div class="premium-table-wrap">
        <table class="premium-table">
          <thead>
            <tr>
              <th>Request Type</th>
              <th>Changing Time</th>
              <th>Reason</th>
              <th>Approved By Manager</th>
              <th>Status</th>
              <th>Requested At</th>
              <th>Resolved At</th>
            </tr>
          </thead>
          <tbody>
            <% @edit_requests.each do |request| %>
              <tr>
                <td><span class="type-tag"><%= request.request_type %></span></td>
                <td>
                  <% if request.requested_clock_in %>
                    <div class="date-cell">
                      <div class="d"><%= request.requested_clock_in.strftime("%b %d, %Y") %></div>
                      <div class="t"><%= request.requested_clock_in.strftime("%I:%M %p") %></div>
                    </div>
                  <% else %>
                    <span class="text-muted">—</span>
                  <% end %>
                </td>
                <td><div class="reason-cell"><%= request.reason %></div></td>
                <td>
                  <span class="pill <%= request.approved_by_manager? ? 'pill--yes' : 'pill--no' %>">
                    <%= request.approved_by_manager? ? 'Yes' : 'No' %>
                  </span>
                </td>
                <td>
                  <span class="pill pill--<%= request.status %>"><%= request.status.capitalize %></span>
                </td>
                <td>
                  <div class="date-cell">
                    <div class="d"><%= request.created_at.strftime("%b %d, %Y") %></div>
                    <div class="t"><%= request.created_at.strftime("%I:%M %p") %></div>
                  </div>
                </td>
                <td>
                  <% if request.resolved_at %>
                    <div class="date-cell">
                      <div class="d"><%= request.resolved_at.strftime("%b %d, %Y") %></div>
                      <div class="t"><%= request.resolved_at.strftime("%I:%M %p") %></div>
                    </div>
                  <% else %>
                    <span class="text-muted">—</span>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="table-empty">
        <i class="bi bi-inbox"></i>
        <h5>No edit requests yet</h5>
        <p class="mb-0">Your submitted clock-in edit requests will appear here.</p>
      </div>
    <% end %>

  </div>
</div>
