  cursor: pointer;
  white-space: nowrap;
  font-family: 'Inter', sans-serif;
  font-size: 0.8rem;
  font-weight: 500;
  color: var(--hd-muted);
  transition: all 0.18s ease;
  user-select: none;
}

.hd-tab:hover:not(.active) {
  border-color: var(--hd-primary);
  color: var(--hd-primary);
  background: rgba(131,107,203,0.06);
}

.hd-tab.active {
  background: var(--hd-grad);
