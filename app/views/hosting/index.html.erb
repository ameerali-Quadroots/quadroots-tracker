// ── BUILD TABS ────────────────────────────────────────────────────────────────
const mgrCounts = {};
for (const months of Object.values(hdData))
  for (const items of Object.values(months))
    for (const it of items)
      mgrCounts[it.manager] = (mgrCounts[it.manager] || 0) + 1;

const tabsRow = document.getElementById('hdTabsRow');
let activeManager = 'All';

function buildTabs() {
  tabsRow.innerHTML = '';

  // "All" tab
  const allTab = document.createElement('button');
  allTab.className = 'hd-tab active';
  allTab.dataset.mgr = 'All';
  allTab.innerHTML = `
    <span class="hd-tab-avatar" style="background:linear-gradient(135deg,#836BCB,#6B5B95)">All</span>
    <span>All Managers</span>
    <span class="hd-tab-count">89</span>`;
  tabsRow.appendChild(allTab);

  for (const [name, cfg] of Object.entries(MANAGERS)) {
    const count = mgrCounts[name] || 0;
    const btn = document.createElement('button');
    btn.className = 'hd-tab';
    btn.dataset.mgr = name;
    btn.innerHTML = `
      <span class="hd-tab-avatar" style="background:${cfg.color}">${cfg.abbr}</span>
      <span>${name}</span>
      <span class="hd-tab-count">${count}</span>`;
    tabsRow.appendChild(btn);
  }

  tabsRow.addEventListener('click', e => {
    const btn = e.target.closest('.hd-tab');
    if (!btn) return;
    tabsRow.querySelectorAll('.hd-tab').forEach(t => t.classList.remove('active'));
    btn.classList.add('active');
    activeManager = btn.dataset.mgr;
    applyFilter(activeManager);
  });
}

// ── FILTER ────────────────────────────────────────────────────────────────────
function applyFilter(mgr) {
  document.querySelectorAll('.hd-domain-row').forEach(row => {
    if (mgr === 'All' || row.dataset.manager === mgr)
      row.classList.remove('hd-filtered');
    else
      row.classList.add('hd-filtered');
  });

  // hide month card columns with no visible rows
  document.querySelectorAll('.hd-month-col').forEach(col => {
    const visible = col.querySelectorAll('.hd-domain-row:not(.hd-filtered)').length;
    col.classList.toggle('hd-hidden', visible === 0);
    // update the count badge
    const badge = col.querySelector('.hd-card-count');
    if (badge) badge.textContent = visible + ' acct' + (visible !== 1 ? 's' : '');
  });

  // hide year blocks where every month card is hidden
  document.querySelectorAll('.hd-year-block').forEach(block => {
    const visibleCols = block.querySelectorAll('.hd-month-col:not(.hd-hidden)').length;
    block.classList.toggle('hd-hidden', visibleCols === 0);
  });
}

// ── CHART ─────────────────────────────────────────────────────────────────────
const mIdx = {January:0,February:1,March:2,April:3,May:4,June:5,July:6,August:7,September:8,October:9,November:10,December:11};
const allMonths = [];
for (const [yr, months] of Object.entries(hdData))
  for (const [mn, items] of Object.entries(months))
    allMonths.push({yr, mn, count: items.length});

const maxC = Math.max(...allMonths.map(m => m.count));
const chartEl = document.getElementById('hdChartArea');
const barAlpha = [1,.9,.82,.76,.7,.64,.58,.78,.72,.86,.94,.68];
allMonths.forEach(m => {
  const h = Math.max(5, (m.count / maxC) * 100);
  const op = barAlpha[mIdx[m.mn] % 12];
  chartEl.innerHTML += `
    <div class="hd-bar-col" title="${m.mn} ${m.yr}: ${m.count}">
      <div class="hd-bar-fill" style="height:${h}%;opacity:${op}"></div>
      <div class="hd-bar-tick">${m.mn.slice(0,3)}<br>'${m.yr.slice(2)}</div>
    </div>`;
});

// ── RENDER CONTENT ────────────────────────────────────────────────────────────
const contentEl = document.getElementById('hdContent');
let delay = 0;

for (const [year, months] of Object.entries(hdData)) {
  const totalYear = Object.values(months).reduce((a, v) => a + v.length, 0);
  const monthList = Object.keys(months);

  const yearBlock = document.createElement('div');
  yearBlock.className = 'hd-year-block';

  const yearHeader = document.createElement('div');
  yearHeader.className = 'hd-year-header';
  yearHeader.innerHTML = `
    <span class="hd-year-num">${year}</span>
    <div>
      <div class="hd-year-meta-count">${totalYear} accounts &middot; ${monthList.length} month${monthList.length > 1 ? 's' : ''}</div>
      <div class="hd-year-meta-span">${monthList[0]} &ndash; ${monthList[monthList.length - 1]}</div>
    </div>`;
  yearBlock.appendChild(yearHeader);

  const row = document.createElement('div');
  row.className = 'row g-4';
  yearBlock.appendChild(row);

  for (const [month, items] of Object.entries(months)) {
    const col = document.createElement('div');
    col.className = 'col-12 col-sm-6 col-lg-4 col-xl-3 hd-month-col';

    const card = document.createElement('div');
    card.className = 'hd-card';
    card.style.animationDelay = `${delay * 35}ms`;
    delay++;

    const domainRows = items.map(it => {
      const mgr = MANAGERS[it.manager] || {color:'#aaa'};
      return `
        <div class="hd-domain-row" data-manager="${it.manager}">
          <span class="hd-d-num">${it.num}</span>
          <span class="hd-d-name" title="${it.domain}">${it.domain}</span>
          <span class="hd-d-dot" style="background:${mgr.color}" title="${it.manager}"></span>
          <span class="hd-d-date">${it.date.slice(5)}</span>
        </div>`;
    }).join('');

    card.innerHTML = `
      <div class="hd-card-head">
        <span class="hd-month-name">${month}</span>
        <span class="hd-card-count">${items.length} acct${items.length > 1 ? 's' : ''}</span>
      </div>
      ${domainRows}`;

    col.appendChild(card);
    row.appendChild(col);
  }

  contentEl.appendChild(yearBlock);
}

buildTabs();
</script>
