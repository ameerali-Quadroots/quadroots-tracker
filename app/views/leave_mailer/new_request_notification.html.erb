<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8">
    <title>New Leave Request Submitted</title>
  </head>
  <body style="margin: 0; padding: 0; font-family: Arial, sans-serif; background-color: #f5f7fa;">

    <table width="100%" cellpadding="0" cellspacing="0" style="padding: 20px;">
      <tr>
        <td align="center">
          <table width="600" cellpadding="0" cellspacing="0" style="background-color: #ffffff; border-radius: 8px; overflow: hidden; box-shadow: 0 2px 5px rgba(0,0,0,0.05);">
            <tr>
              <td style="background-color: #27ae60; padding: 20px; text-align: center;">
                <h2 style="color: #ffffff; margin: 0;">New Leave Request Submitted</h2>
              </td>
            </tr>

            <tr>
              <td style="padding: 30px;">
                <p style="font-size: 16px; color: #333;">Hello,</p>

                <p style="font-size: 16px; color: #333;">
                  A new leave request has been submitted by:
                  <strong><%= @leave.user.name %></strong> (<%= @leave.user.email %>)
                </p>

                <table cellpadding="0" cellspacing="0" width="100%" style="margin-top: 20px; border-collapse: collapse;">
                  <tr>
                    <td style="padding: 8px; background-color: #f0f4f8; font-weight: bold; width: 200px;">Leave Type:</td>
                    <td style="padding: 8px; text-transform: capitalize;"><%= @leave.leave_type.humanize %></td>
                  </tr>
                  <tr>
                    <td style="padding: 8px; background-color: #f0f4f8; font-weight: bold;">Department:</td>
                    <td style="padding: 8px;"><%= @leave.user.department %></td>
                  </tr>
                  <tr>
                    <td style="padding: 8px; background-color: #f0f4f8; font-weight: bold;">From:</td>
                    <td style="padding: 8px;"><%= @leave.start_date.strftime("%A, %d %B %Y") %></td>
                  </tr>
                  <tr>
                    <td style="padding: 8px; background-color: #f0f4f8; font-weight: bold;">To:</td>
                    <td style="padding: 8px;"><%= @leave.end_date.strftime("%A, %d %B %Y") %></td>
                  </tr>
                  <tr>
                    <td style="padding: 8px; background-color: #f0f4f8; font-weight: bold;">Reason:</td>
                    <td style="padding: 8px;"><%= @leave.reason %></td>
                  </tr>
                  <tr>
                    <td style="padding: 8px; background-color: #f0f4f8; font-weight: bold;">Status:</td>
                    <td style="padding: 8px; text-transform: capitalize;"><%= @leave.status %></td>
                  </tr>
                </table>

                <p style="font-size: 14px; color: #666; margin-top: 30px;">
                  Please log in to review and take action on this request.
                </p>

                <p style="text-align: center; margin-top: 20px;">
                  <a href="<%= root_url %>" style="background-color: #27ae60; color: white; padding: 12px 24px; text-decoration: none; border-radius: 4px;">Go to Dashboard</a>
                </p>
              </td>
            </tr>

            <tr>
              <td style="background-color: #f5f7fa; padding: 20px; text-align: center; font-size: 12px; color: #999;">
                © <%= Time.current.year %> QuadRoots. All rights reserved.
              </td>
            </tr>

          </table>
        </td>
      </tr>
    </table>

  </body>
</html>
